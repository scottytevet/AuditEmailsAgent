# Default provider for generated answers and embeddings.
# Use Azure AI Foundry unless you explicitly switch this to openai.
LLM_PROVIDER=azure_foundry

# Recommended Azure AI Foundry v1/OpenAI-compatible endpoint.
# Works with either services.ai.azure.com or openai.azure.com Foundry/OpenAI resources.
AZURE_FOUNDRY_ENDPOINT=https://YOUR-RESOURCE-NAME.services.ai.azure.com/openai/v1
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_ANSWER_MODEL=gpt-4.1-mini
AZURE_FOUNDRY_EMBEDDING_MODEL=text-embedding-3-small

# Optional: classic Foundry model inference endpoint style.
# AZURE_FOUNDRY_ENDPOINT=https://YOUR-RESOURCE-NAME.services.ai.azure.com/models
# AZURE_FOUNDRY_API_STYLE=model_inference
# AZURE_FOUNDRY_API_VERSION=2024-05-01-preview

# Optional public OpenAI fallback.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_ANSWER_MODEL=gpt-4.1-mini

# Optional override. By default the DB is stored under %LOCALAPPDATA%\PeakSalesEmailMVP.
# EMAIL_MVP_DB=C:\Users\YourName\AppData\Local\PeakSalesEmailMVP\email_mvp.sqlite
EMAIL_MVP_HOST=127.0.0.1
EMAIL_MVP_PORT=8765
# UI/source catalog metadata. The app also generates AI-Outputs\sources.json from indexed records.
APP_TITLE=Source Evidence QA
APP_SUBTITLE=Ask questions across indexed source records.
SOURCE_ENV_LABEL=Production source index
# SOURCE_CATALOG_PATH=C:\path\to\AI-Outputs\sources.json
# Optional Microsoft Entra authentication. Enable this in production so only TEVET users can access the app.
AUTH_ENABLED=false
AUTH_TENANT_ID=YOUR-TEVET-TENANT-GUID
AUTH_CLIENT_ID=YOUR-ENTRA-APP-CLIENT-ID
AUTH_CLIENT_SECRET=YOUR-ENTRA-APP-CLIENT-SECRET-VALUE
AUTH_REDIRECT_URI=http://127.0.0.1:8765/auth/callback
AUTH_ALLOWED_DOMAIN=tevet.com
AUTH_SESSION_SECRET=generate-a-long-random-value-at-least-32-characters
AUTH_SESSION_SECONDS=28800
AUTH_COOKIE_NAME=communications_evidence_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
# AUTH_PUBLIC_ORIGIN=https://your-production-host
